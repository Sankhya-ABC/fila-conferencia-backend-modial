generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  ADMINISTRADOR
  SEPARADOR
}

enum DbDialect {
  SQLSERVER
  ORACLE
}

model User {
  id           String   @id @default(uuid())

  codigo       Int      @unique
  nome         String
  email        String   @unique
  foto         String?
  perfil       Perfil

  senha        String?
  ativo        Boolean  @default(false)

  resetToken      String?
  resetTokenExp   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Dominio {
  id        Int    @id @default(autoincrement())
  tipo      String
  codigo    String
  descricao String

  @@unique([tipo, codigo])
}

model Empresa {
  codigo   Int     @id
  nome     String
  cpfCnpj String?
}

model Parceiro {
  codigo   Int     @id
  nome     String
  cpfCnpj String?
}

model SessaoConferencia {
  id                    String   @id @default(uuid())
  numeroUnico           Int      @unique
  numeroConferencia     Int
  idUsuario             Int
  codigoTipoMovimento   String?
  descricaoTipoOperacao String?
  formacaoVolumes       String?
  buscarCodigoBarraPor  String   @default("A")
  status                String   @default("A")
  criadoEm              DateTime @default(now())

  qtdVol      Int?
  altura      Float?
  largura     Float?
  comprimento Float?
  peso        Float?

  dtAbertura   DateTime?
  dtFechamento DateTime?

  itens    SessaoItem[]
  volumes  SessaoVolume[]
  leituras SessaoLeitura[]
  codigos  SessaoCodigoBarras[]
  itensUma SessaoItemUma[]
}

model SessaoItem {
  id           String            @id @default(uuid())
  sessaoId     String
  sessao       SessaoConferencia @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  sequencia           Int
  idProduto           Int
  nomeProduto         String
  complemento         String?
  marca               String?
  referencia          String?
  unidade             String
  unidadePadrao       String?
  controle            String    @default(" ")
  tipControle         String?
  decQtd              Int       @default(0)
  pesoBruto           Float     @default(0)

  qtdNeg              Float
  qtdEntregue         Float     @default(0)
  qtdConferidaSankhya Float     @default(0)
  qtdConferidaLocal   Float     @default(0)

  divideMult   String?
  fatorConv    Float?
  imagem       String?
  lisControles String?
  usaConfPeso  Boolean   @default(false)
  pesavel      Boolean   @default(false)

  @@unique([sessaoId, sequencia])
}

model SessaoVolume {
  id          String            @id @default(uuid())
  sessaoId    String
  sessao      SessaoConferencia @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  seqVol      Int
  ordem       Int
  altura      Float?
  largura     Float?
  comprimento Float?
  peso        Float?

  @@unique([sessaoId, seqVol])
}

model SessaoLeitura {
  id           String            @id @default(uuid())
  sessaoId     String
  sessao       SessaoConferencia @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  seqVol       Int
  idProduto    Int
  unidade      String
  controle     String    @default(" ")
  codigoBarras String?
  qtd          Float
  qtdVolpad    Float
  peso         Float?
  criadoEm     DateTime  @default(now())
}

model Balanca {
  id              String  @id @default(uuid())
  nome            String
  fabricante      String  @default("Toledo")
  modelo          String?
  tipoComunicacao String  @default("HTTP") // SERIAL_RS232 | SERIAL_USB | HTTP | TOLEDO_TCP
  // Serial
  portaCom        String?
  baudRate        Int     @default(4800)
  dataBits        Int     @default(8)
  paridade        String  @default("NONE")
  stopBits        Int     @default(1)
  protocoloSerial String  @default("P05")
  // Network (backward compat)
  protocolo       String  @default("HTTP")
  ip              String?
  porta           Int?
  rota            String  @default("/peso")
  ativo           Boolean @default(true)
}

model SessaoItemUma {
  id        String            @id @default(uuid())
  sessaoId  String
  sessao    SessaoConferencia @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  idProduto Int
  codUma    String
  descricao String
  peso      Float?
  codVol    String?
  codBarra  String?
  padrao    Boolean           @default(false)

  @@unique([sessaoId, idProduto, codUma])
}

model SessaoCodigoBarras {
  id          String            @id @default(uuid())
  sessaoId    String
  sessao      SessaoConferencia @relation(fields: [sessaoId], references: [id], onDelete: Cascade)

  codigoBarra String
  idProduto   Int
  unidade     String?
  controle    String    @default(" ")
  quantidade  Float?
  divideMult  String?
  origem      String    @default("BAR")
}

model ProdutoCache {
  idProduto   Int      @id
  nome        String
  complemento String?
  imagem      String?
  syncAt      DateTime @updatedAt
}

model LogLogin {
  id        String   @id @default(uuid())
  idUsuario Int
  criadoEm  DateTime @default(now())
}

model LogHeartbeat {
  id                String   @id @default(uuid())
  idUsuario         Int
  numeroConferencia Int?
  criadoEm          DateTime @default(now())
}

model CodigoBarrasCache {
  id          String   @id @default(uuid())
  codigoBarra String
  idProduto   Int
  codvol      String?
  controle    String   @default(" ")
  quantidade  Float?
  divideMult  String?
  origem      String   @default("BAR")

  @@unique([codigoBarra, idProduto, controle, origem])
}

// ─── Multitenancy (usados apenas no DB admin) ────────────────────────────────

model MasterUser {
  id       String  @id @default(uuid())
  email    String  @unique
  nome     String
  senha    String
  ativo    Boolean @default(true)
}

model Tenant {
  slug            String       @id
  nome            String
  ativo           Boolean      @default(true)
  dbUrl           String
  snkHost         String
  snkGateway      String
  snkXToken       String
  snkClientId     String
  snkClientSecret String
  dbDialect       DbDialect    @default(SQLSERVER)
  snkModulos      String       @default("AD_NUMTALAO,AD_TIPOENTREGA,AD_CUBAGEM")
  criadoEm        DateTime     @default(now())
  usuarios        TenantUser[]
}

model TenantUser {
  email      String  @id
  tenantSlug String
  tenant     Tenant  @relation(fields: [tenantSlug], references: [slug])
}